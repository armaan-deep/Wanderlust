<%layout("/layouts/boiler")%>
   <div class="heading mt-4 ">
    <h2> <%= filter.toUpperCase().split("-").join(" ") %></h2>
   </div>
<div class="card-cont mt-5">
    <%for(list of lists){%>
      <a href="/listings/<%= list._id %>">
      <div class="card card-srch">
        <img class="card-img-top " src="<%= list.image.url %>" alt="<%= list.id %> iamge">
            <div class="card-img-overlay"></div>
    
        <div class="card-body">
          <p class="card-text"><%= list.title %><br/>
            &#8377 <%=list.price?.toLocaleString("en-IN")%>/night
              <i class="tax-info">&plus; &nbsp; 27% GST</i>  
          </p>
        </div>
      </div>
      
    <%} %> 
  </a>
</div>
</form>
